/// drm.zig — Framebuffer directo via /dev/fb0
/// Para virtio-gpu en Proxmox/QEMU que no expone dumb buffers KMS

const std = @import("std");
const linux = std.os.linux;

const FBIOGET_VSCREENINFO: u32 = 0x4600;
const FBIOGET_FSCREENINFO: u32 = 0x4602;

pub const FbVarScreenInfo = extern struct {
    xres: u32, yres: u32,
    xres_virtual: u32, yres_virtual: u32,
    xoffset: u32, yoffset: u32,
    bits_per_pixel: u32,
    grayscale: u32,
    red_offset: u32, red_length: u32, red_msb_right: u32,
    green_offset: u32, green_length: u32, green_msb_right: u32,
    blue_offset: u32, blue_length: u32, blue_msb_right: u32,
    transp_offset: u32, transp_length: u32, transp_msb_right: u32,
    nonstd: u32, activate: u32,
    height: u32, width: u32,
    accel_flags: u32,
    pixclock: u32,
    left_margin: u32, right_margin: u32,
    upper_margin: u32, lower_margin: u32,
    hsync_len: u32, vsync_len: u32,
    sync: u32, vmode: u32,
    rotate: u32, colorspace: u32,
    reserved: [4]u32,
};

pub const FbFixScreenInfo = extern struct {
    id: [16]u8,
    smem_start: u64,
    smem_len: u32,
    type: u32,
    type_aux: u32,
    visual: u32,
    xpanstep: u16, ypanstep: u16, ywrapstep: u16,
    line_length: u32,
    mmio_start: u64,
    mmio_len: u32,
    accel: u32,
    capabilities: u16,
    reserved: [2]u16,
};

pub const Framebuffer = struct {
    width : u32,
    height: u32,
    pitch : u32,
    size  : u64,
    data  : []u32,
    ptr   : [*]u8,

    pub inline fn setPixel(self: *Framebuffer, x: u32, y: u32, color: u32) void {
        if (x >= self.width or y >= self.height) return;
        self.data[y * (self.pitch / 4) + x] = color;
    }

    pub fn fillRect(self: *Framebuffer, x: u32, y: u32, w: u32, h: u32, color: u32) void {
        const x1 = @min(x + w, self.width);
        const y1 = @min(y + h, self.height);
        var py = y;
        while (py < y1) : (py += 1) {
            var px = x;
            while (px < x1) : (px += 1) {
                self.data[py * (self.pitch / 4) + px] = color;
            }
        }
    }

    pub fn clear(self: *Framebuffer, color: u32) void {
        @memset(self.data, color);
    }
};

pub const Output = struct {
    width : u32,
    height: u32,
    fb    : Framebuffer,
    fd       : i32,
    fd_write : i32 = -1,

    pub fn drawBuffer(self: *Output) *Framebuffer { return &self.fb; }

    // Con /dev/fb0 no hay page flip — escribimos directo
    // En el futuro podemos hacer doble buffer con pan
    pub fn pageFlip(self: *Output, _: i32) !void {
        if (self.fd_write >= 0) {
            const bytes = std.mem.sliceAsBytes(self.fb.data);
            _ = std.os.linux.lseek(@intCast(self.fd_write), 0, std.os.linux.SEEK.SET);
            var off: usize = 0;
            while (off < bytes.len) {
                const r = std.os.linux.write(@intCast(self.fd_write), bytes.ptr + off, bytes.len - off);
                const n = @as(isize, @bitCast(r));
                if (n <= 0) break;
                off += @intCast(n);
            }
        }
    }
};

pub const Device = struct {
    fd       : i32,
    output   : ?Output = null,
    allocator: std.mem.Allocator,

    pub fn autoDetect(allocator: std.mem.Allocator) !Device {
        // Primero intentar /dev/fb0
        var path: [16:0]u8 = std.mem.zeroes([16:0]u8);
        _ = std.fmt.bufPrint(&path, "/dev/fb0", .{}) catch unreachable;
        const rc = linux.open(&path, .{ .ACCMODE = .RDWR }, 0);
        const fd: i32 = @bitCast(@as(u32, @truncate(rc)));
        if (fd >= 0) {
            std.log.info("drm: usando /dev/fb0", .{});
            return Device{ .fd = fd, .allocator = allocator };
        }
        return error.NoDrmDevice;
    }

    pub fn detectOutput(self: *Device) !void {
        var vinfo: FbVarScreenInfo = std.mem.zeroes(FbVarScreenInfo);
        var finfo: FbFixScreenInfo = std.mem.zeroes(FbFixScreenInfo);

        const r1 = linux.ioctl(self.fd, FBIOGET_VSCREENINFO, @intFromPtr(&vinfo));
        if (@as(i32, @bitCast(@as(u32, @truncate(r1)))) < 0) return error.IoctlFailed;
        const r2 = linux.ioctl(self.fd, FBIOGET_FSCREENINFO, @intFromPtr(&finfo));
        if (@as(i32, @bitCast(@as(u32, @truncate(r2)))) < 0) return error.IoctlFailed;

        const width  = vinfo.xres;
        const height = vinfo.yres;
        const pitch  = finfo.line_length;
        const size   = @as(u64, pitch) * height;

        std.log.info("drm: framebuffer {}x{} {}bpp pitch={}", .{
            width, height, vinfo.bits_per_pixel, pitch,
        });

        const ptr = try std.posix.mmap(
            null, size,
            std.posix.PROT{ .READ = true, .WRITE = true },
            .{ .TYPE = .SHARED },
            self.fd, 0,
        );

        const pixels = @as([*]u32, @ptrCast(@alignCast(ptr.ptr)))[0..size/4];

        self.output = Output{
            .width    = width,
            .height   = height,
            .fd       = self.fd,
            .fd_write = self.fd,
            .fb       = Framebuffer{
                .width  = width,
                .height = height,
                .pitch  = pitch,
                .size   = size,
                .data   = pixels,
                .ptr    = ptr.ptr,
            },
        };
    }

    pub fn close(self: *Device) void {
        if (self.output) |*out| {
            std.posix.munmap(@alignCast(out.fb.ptr[0..out.fb.size]));
        }
        _ = linux.close(@intCast(self.fd));
    }
};
